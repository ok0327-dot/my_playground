# === 필수 ===
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret
GOOGLE_SHEETS_CREDENTIALS={"type":"service_account","project_id":"..."}
GOOGLE_SHEET_ID=your-spreadsheet-id

# === AI 제공자 (최소 하나 필수) ===
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key

# AI_PROVIDER: "gemini" (기본값) 또는 "groq"
# Primary 실패 시 다른 제공자로 자동 전환 (Fallback)
AI_PROVIDER=gemini

# === 선택 (미국 경제지표) ===
FRED_API_KEY=your-fred-api-key

# === 선택 (쿠팡 파트너스) ===
COUPANG_ACCESS_KEY=
COUPANG_SECRET_KEY=

# === 수동 토픽 (쉼표 구분, 비어있으면 자동 수집만 사용) ===
# 예: MANUAL_TOPICS=비트코인 반감기,금리 인하 전망
MANUAL_TOPICS=

# === 출력 설정 ===
OUTPUT_DIR=outputs
SAVE_LOCAL_MARKDOWN=true

# === 옵션 ===
DRY_RUN=false
LOG_LEVEL=INFO
